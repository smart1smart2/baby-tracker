                      font=\gostfont\large]
    \tikzstyle{every state} = [rectangle,rounded corners]
    \node[initial,state] (A)              {AWAITING\_HANDSHAKE};
    \node[state]         (B) [below of=A] {AWAITING\_TUNNEL};
